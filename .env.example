# Authentication
AUTH_SECRET="your-auth-secret-here" # Generate with: npx auth

# GitHub OAuth
AUTH_GITHUB_ID=your-github-client-id
AUTH_GITHUB_SECRET=your-github-client-secret

# Database
MONGODB_URI=your-mongodb-uri-here
DATABASE_NAME="env-store" # Optional: defaults to "env-store"

# Encryption
ENCRYPTION_SECRET="your-encryption-secret-here" # Generate with: openssl rand -base64 32
